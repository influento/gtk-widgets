#!/usr/bin/env bash
set -euo pipefail

# Generic toggle for GTK4 widget popups. Uses flock to prevent duplicates.
# Usage: widget-toggle <widget-name>

WIDGET="${1:?Usage: widget-toggle <widget-name>}"
WIDGET_PATH="$HOME/.local/bin/$WIDGET"
LOCKFILE="/tmp/.${WIDGET}-toggle.lock"
PIDFILE="/tmp/.${WIDGET}-toggle.pid"

exec 9>"$LOCKFILE"
if ! flock -n 9; then
  # Lock is held — widget is running, kill it
  if [[ -f "$PIDFILE" ]]; then
    pid="$(cat "$PIDFILE")"
    kill "$pid" 2>/dev/null || true
  fi
  exit 0
fi

# Lock acquired — launch widget (preload layer-shell so widgets skip re-exec)
export LD_PRELOAD="${LD_PRELOAD:+$LD_PRELOAD:}/usr/lib/libgtk4-layer-shell.so"
"$WIDGET_PATH" &
echo $! > "$PIDFILE"
wait $! 2>/dev/null || true
rm -f "$PIDFILE"
