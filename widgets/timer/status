#!/usr/bin/env python3
"""Waybar status output for the timer widget.

Outputs JSON: { "text": "...", "tooltip": "...", "class": "..." }
Also fires the alarm (notify-send + paplay) when a running timer hits zero.
Idempotent: the `fired` flag in the state file prevents repeat alarms.
"""

import json
import os
import shutil
import subprocess
import sys

_DIR = os.path.dirname(os.path.realpath(__file__))
sys.path.insert(0, _DIR)

import state as ts  # noqa: E402

ICON_IDLE = ""  # nf-fa-clock_o
ICON_RUNNING = ""  # nf-fa-hourglass_half
ICON_PAUSED = ""  # nf-fa-pause
ICON_DONE = ""  # nf-fa-bell

SOUND_CANDIDATES = [
    "/usr/share/sounds/freedesktop/stereo/complete.oga",
    "/usr/share/sounds/freedesktop/stereo/alarm-clock-elapsed.oga",
    "/usr/share/sounds/freedesktop/stereo/bell.oga",
]


def _fire_alarm():
    if shutil.which("notify-send"):
        subprocess.Popen(
            ["notify-send", "-u", "critical", "-a", "Timer", "Timer", "Time's up!"],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
    sound = next((p for p in SOUND_CANDIDATES if os.path.exists(p)), None)
    if sound and shutil.which("paplay"):
        subprocess.Popen(
            ["paplay", sound],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )


def main():
    state = ts.load()

    # Fire alarm once when a running timer crosses zero
    if (state["mode"] == "timer"
            and state["running"]
            and ts.remaining(state) == 0.0
            and not state["fired"]):
        _fire_alarm()
        ts.pause(state)
        state["fired"] = True
        ts.save(state)

    if ts.is_idle(state):
        print(json.dumps({"text": ICON_IDLE, "class": "idle"}))
        return

    secs = ts.display_seconds(state)
    text = f"{ICON_RUNNING if state['running'] else ICON_PAUSED}  {ts.format_hms(secs)}"

    cls = "running" if state["running"] else "paused"
    tooltip = f"{state['mode'].capitalize()} ({cls})"

    if state["mode"] == "timer" and ts.remaining(state) == 0.0 and state["duration"] > 0:
        text = f"{ICON_DONE}  00:00:00"
        cls = "alarm"
        tooltip = "Timer finished"

    print(json.dumps({"text": text, "class": cls, "tooltip": tooltip}))


if __name__ == "__main__":
    main()
